    "@radix-ui/react-toast": "^1.2.17",
    "@reduxjs/toolkit": "^2.2.7",
    "@tanstack/react-query": "^5.51.21",
    "@tanstack/react-query-devtools": "^5.51.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.15.0",
    "framer-motion": "^11.3.28",
